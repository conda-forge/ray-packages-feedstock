From b0da46c66750e72926cdf678b4e0576bbf2c913f Mon Sep 17 00:00:00 2001
From: Lonnie Liu <lonnie@anyscale.com>
Date: Wed, 15 Oct 2025 16:30:33 +0000
Subject: [PATCH 8/8] [bazel] disable strict env

Signed-off-by: Lonnie Liu <lonnie@anyscale.com>
---
 .bazelrc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.bazelrc b/.bazelrc
index b618d3759b..9ba0abe465 100644
--- a/.bazelrc
+++ b/.bazelrc
@@ -3,7 +3,7 @@ common --noenable_bzlmod
 # Must be first. Enables build:windows, build:linux, build:macos, build:freebsd, build:openbsd
 build --enable_platform_specific_config
 
-build --incompatible_strict_action_env
+# build --incompatible_strict_action_env
 build:strict --incompatible_strict_action_env
 
 build:linux --workspace_status_command="bash ./bazel/workspace_status.sh"
